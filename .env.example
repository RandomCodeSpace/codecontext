# LLM Provider Configuration
# Choose one: ollama, azure, openai
LLM_PROVIDER=ollama

# Common settings
LLM_MODEL=llama2
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=2000
LLM_TIMEOUT_SECONDS=30

# Ollama Configuration (for local LLM)
OLLAMA_BASE_URL=http://localhost:11434

# Azure OpenAI Configuration
# AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
# AZURE_OPENAI_KEY=your-api-key
# AZURE_OPENAI_DEPLOYMENT=deployment-name
# AZURE_OPENAI_API_VERSION=2024-02-15-preview

# OpenAI Configuration
# OPENAI_API_KEY=sk-your-api-key
# OPENAI_MODEL=gpt-4

# Instructions:
# 1. Copy this file to .env.local for local overrides (not committed to git)
# 2. Or copy to .env for project-wide defaults (commit to repo)
# 3. Set LLM_PROVIDER to one of: ollama, azure, openai
# 4. Configure the corresponding provider's settings
# 5. For Ollama, make sure the service is running: ollama serve
# 6. For Azure/OpenAI, provide your API credentials
